---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../css/styles.css'; // Importa el CSS global
---

<!DOCTYPE html>
<html lang="es" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>Ubot - IA para Exámenes de Admisión UCR, UNA y TEC (Costa Rica)</title>
  <meta name="description" content="Ubot es tu asistente de inteligencia artificial exclusivo para prepararte para los exámenes de admisión de las universidades estatales de Costa Rica." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://ubotcr.com/" />
  
  <meta name="generator" content={Astro.generator} />

  <!-- Structured Data (Organization) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Ubot",
    "url": "https://ubotcr.com",
    "description": "Asistente de inteligencia artificial diseñado exclusivamente para la prep...",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Web",
    "potentialAction": [
      {
        "@type": "Action",
        "name": "Chat con IA",
        "target": "https://chat.ubotcr.com"
      }
    ]
  }
  </script>

  <!-- Swiper CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
</head>
<body>

  <Nav />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Swiper JS Global -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <!-- Main JS -->
  <script src="../js/main.js"></script>
</body>
</html>
